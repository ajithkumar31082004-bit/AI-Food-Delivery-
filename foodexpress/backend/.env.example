PORT=5000

# --- Supabase (PostgreSQL) ---
# Get this from: Supabase Dashboard > Project Settings > Database > Connection String (URI mode)
DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres

# --- Local development only (optional if using DATABASE_URL) ---
# DB_HOST=127.0.0.1
# DB_USER=postgres
# DB_PASSWORD=your_password
# DB_NAME=foodexpress

# --- Auth ---
JWT_SECRET=replace_this_with_secure_secret_min_32_chars
JWT_EXPIRES_IN=7d

# --- Google Gemini AI ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- CORS: set to your Vercel frontend URL in production ---
CLIENT_URL=http://localhost:3000
# CORS_ORIGIN=https://your-app.vercel.app
