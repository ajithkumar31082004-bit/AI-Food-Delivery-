{
  "$schema": "https://schema.railway.app/railway-config.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd foodexpress/backend && npm install"
  },
  "deploy": {
    "startCommand": "cd foodexpress/backend && node src/index.js",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
